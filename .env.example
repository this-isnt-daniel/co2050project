# ============================================================
# Forensic Medicine Department API — Environment Configuration
# Copy this file to .env and fill in real values.
# NEVER commit .env to version control.
# ============================================================

# --- PostgreSQL ---
POSTGRES_DB=forensic_dept
POSTGRES_USER=forensic_user
POSTGRES_PASSWORD=change_me_strong_password
POSTGRES_PORT=5432

# --- Spring datasource (used by the app container or local run) ---
DB_HOST=localhost
DB_PORT=5432
DB_NAME=forensic_dept
DB_USER=forensic_user
DB_PASSWORD=change_me_strong_password

# --- JWT ---
# Generate a strong random secret (e.g. openssl rand -hex 64)
JWT_SECRET=replace_with_at_least_64_hex_chars_secret_key_here_do_not_use_this_in_production
JWT_EXPIRATION_MS=86400000

# --- Application ---
APP_PORT=8080
DOCUMENT_STORAGE_PATH=/data/documents
NOTIFICATION_PENDING_REPORT_THRESHOLD_DAYS=7
NOTIFICATION_COURT_DATE_UPCOMING_DAYS=14

# --- CORS ---
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
